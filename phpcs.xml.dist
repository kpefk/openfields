<?xml version="1.0"?>
<ruleset name="OpenFields">
	<description>Coding standards for the OpenFields plugin.</description>

	<file>.</file>

	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/assets/build/*</exclude-pattern>
	<exclude-pattern>/tests/*</exclude-pattern>
	<!-- "Silence is golden" directory-index stubs carry no logic to sniff. -->
	<exclude-pattern>*/index.php</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg name="basepath" value="."/>
	<arg name="parallel" value="8"/>
	<arg value="ps"/>

	<config name="minimum_wp_version" value="6.4"/>
	<config name="testVersion" value="8.1-"/>

	<rule ref="WordPress-Extra">
		<!-- PSR-4 class files use StudlyCase names, not hyphenated WP file names. -->
		<exclude name="WordPress.Files.FileName"/>
		<!-- Template-method base/overridable methods keep contract params unused. -->
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>
	</rule>
	<rule ref="WordPress-Docs"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="openfields"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="openfields"/>
				<element value="OpenFields"/>
				<element value="OPENFIELDS"/>
			</property>
		</properties>
	</rule>

	<!-- OpenFields uses ACF-style namespaced hooks, e.g. "openfields/booted". -->
	<rule ref="WordPress.NamingConventions.ValidHookName">
		<properties>
			<property name="additionalWordDelimiters" value="/"/>
		</properties>
	</rule>
</ruleset>
