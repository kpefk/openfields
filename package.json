{
	"name": "openfields",
	"version": "0.1.0-alpha",
	"description": "Open Source custom fields, field groups and content builders for WordPress.",
	"license": "GPL-2.0-or-later",
	"private": true,
	"homepage": "https://github.com/kpefk/openfields",
	"repository": {
		"type": "git",
		"url": "https://github.com/kpefk/openfields.git"
	},
	"scripts": {
		"build": "wp-scripts build --webpack-src-dir=assets/src --output-path=assets/build",
		"start": "bun run generate:types && wp-scripts start --webpack-src-dir=assets/src --output-path=assets/build",
		"generate:types": "node ./tools/generate-types.mjs",
		"watch:types": "node ./tools/generate-types.mjs --watch",
		"type-check": "tsc --noEmit",
		"test:js": "wp-scripts test-unit-js",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"format": "wp-scripts format",
		"make-pot": "wp-scripts i18n make-pot . languages/openfields.pot --domain=openfields",
		"env": "wp-env",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop"
	},
	"devDependencies": {
		"@types/react": "^18.3.0",
		"@types/wordpress__block-editor": "^11.0.0",
		"@types/wordpress__components": "^23.0.0",
		"@types/wordpress__data": "^6.0.0",
		"@wordpress/components": "^28.0.0",
		"@wordpress/element": "^6.0.0",
		"@wordpress/env": "^10.0.0",
		"@wordpress/i18n": "^5.0.0",
		"@wordpress/scripts": "^30.0.0",
		"json-schema-to-typescript": "^15.0.0",
		"typescript": "^5.5.0"
	}
}
