# Normalize line endings to LF across platforms.
* text=auto eol=lf

*.php text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.css text eol=lf
*.txt text eol=lf

# Binary / generated
bun.lockb binary
*.png binary
*.jpg binary
*.gif binary
*.mo binary

# Files excluded from the distributed plugin zip.
/.github export-ignore
/tests export-ignore
/docs export-ignore
/.wp-env.json export-ignore
/TOR.md export-ignore
/CLAUDE.md export-ignore
