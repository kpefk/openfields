{
	"name": "kpefk/openfields",
	"description": "Open Source custom fields, field groups and content builders for WordPress — a GPL-compatible alternative to ACF PRO.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"custom-fields",
		"acf",
		"field-groups",
		"gutenberg"
	],
	"homepage": "https://github.com/kpefk/openfields",
	"support": {
		"issues": "https://github.com/kpefk/openfields/issues",
		"source": "https://github.com/kpefk/openfields"
	},
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpstan/phpstan": "^1.12",
		"szepeviktor/phpstan-wordpress": "^1.3"
	},
	"autoload": {
		"psr-4": {
			"OpenFields\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OpenFields\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpstan": "phpstan analyse --memory-limit=1G",
		"test": "phpunit"
	},
	"config": {
		"sort-packages": true,
		"platform": {
			"php": "8.1"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
